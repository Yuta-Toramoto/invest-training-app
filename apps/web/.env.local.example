# アプリのURL（開発: localhost, 本番: Vercelのドメイン）
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase — ダッシュボード > Settings > API から取得
NEXT_PUBLIC_SUPABASE_URL=https://<ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Drizzle DB接続（ダッシュボード > Settings > Database > Connection string）
# Phase 3 で tRPC を実装するときに必要
# DATABASE_URL=postgresql://postgres.<ref>:[DB_PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres
